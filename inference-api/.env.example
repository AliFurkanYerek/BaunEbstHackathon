# Roboflow: https://app.roboflow.com/settings/api — asla frontend'e koymayın
ROBOFLOW_API_KEY=your_new_api_key_here

# Birden fazla Universe modeli (virgülle); IoU ile çift kutular birleştirilir
ROBOFLOW_MODEL_IDS=earthquake-damage-detection-xmfgr/1,collapsed-building-detection2-ku0yq/1
# Tek model için alternatif:
# ROBOFLOW_MODEL_ID=earthquake-damage-detection-xmfgr/1

ROBOFLOW_CLASSES=collapsed
ROBOFLOW_CONFIDENCE=30
ROBOFLOW_MERGE_IOU=0.42

# GeoSeer hasar fotoğrafı konumu (EXIF yoksa) — https://geoseeer.com/api-docs
GEOSEER_API_KEY=
GEOSEER_ANALYSIS_MODE=fast

PORT=5000
